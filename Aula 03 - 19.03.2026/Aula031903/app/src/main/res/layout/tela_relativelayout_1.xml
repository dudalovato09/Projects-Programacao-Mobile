<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E3EDFB"
        android:padding="10dp">

        <View
            android:id="@+id/bloco1"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="5dp"
            android:background="#0072CE" />

        <View
            android:id="@+id/bloco_vertical"
            android:layout_width="80dp"
            android:layout_height="200dp"
            android:layout_below="@id/bloco1"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="5dp"
            android:background="#0072CE" />

        <View
            android:id="@+id/bloco_meio"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_below="@id/bloco1"
            android:layout_marginTop="100dp"
            android:layout_marginEnd="20dp"
            android:layout_toStartOf="@id/bloco_vertical"
            android:background="#0072CE" />

        <View
            android:id="@+id/bloco_esq"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_below="@id/bloco_vertical"
            android:layout_alignParentStart="true"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="5dp"
            android:background="#0072CE" />

        <View
            android:id="@+id/bloco_dir"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_below="@id/bloco_vertical"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="5dp"
            android:layout_toEndOf="@id/bloco_esq"
            android:background="#0072CE" />

        <View
            android:id="@+id/bloco_final"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_below="@id/bloco_dir"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="5dp"
            android:background="#0072CE" />
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>